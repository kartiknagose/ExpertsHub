// Prisma schema for UrbanPro v2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  MORE_INFO
}

enum VerificationDocumentType {
  ID_PROOF
  EXPERIENCE_LETTER
  CERTIFICATION
  PORTFOLIO
  ADDRESS_PROOF
}

enum VerificationMediaType {
  VIDEO_INTRO
  PORTFOLIO_IMAGE
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  mobile        String    @unique
  passwordHash  String
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  emailVerifiedAt DateTime?
  profilePhotoUrl String?
  isProfileComplete Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  workerProfile WorkerProfile?

  bookingsCustomer Booking[] @relation("customerBookings")

  reviewsWritten  Review[] @relation("reviewsWritten")
  reviewsReceived Review[] @relation("reviewsReceived")
  emailVerifications EmailVerification[]
  passwordResetTokens PasswordResetToken[]
  workerVerificationApplications WorkerVerificationApplication[]
  payments Payment[]
}

model EmailVerification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  token     String    @unique
  verified  Boolean   @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([email])
  @@index([token])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Address {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Service {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  category     String?
  basePrice    Decimal?
  translations Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workers  WorkerService[]
  bookings Booking[]
}

model WorkerProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id])
  bio          String?
  skills       Json?
  hourlyRate   Decimal?
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  serviceAreas Json?
  isVerified   Boolean  @default(false)
  isProbation  Boolean  @default(true)
  verificationScore Int? 

  availability Availability[]
  services     WorkerService[]
  bookingsWorker Booking[] @relation("bookingsWorker")
}

model WorkerVerificationApplication {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      VerificationStatus @default(PENDING)
  score       Int?      
  notes       String?
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  documents   WorkerVerificationDocument[]
  references  WorkerVerificationReference[]
  media       WorkerVerificationMedia[]

  @@index([userId])
  @@index([status])
}

model WorkerVerificationDocument {
  id            Int       @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          VerificationDocumentType
  url           String
  createdAt     DateTime  @default(now())

  @@index([applicationId])
  @@index([type])
}

model WorkerVerificationReference {
  id            Int       @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  relation      String?
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([applicationId])
  @@index([phone])
}

model WorkerVerificationMedia {
  id            Int       @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          VerificationMediaType
  url           String
  createdAt     DateTime  @default(now())

  @@index([applicationId])
  @@index([type])
}

model WorkerService {
  workerId Int
  serviceId Int
  worker   WorkerProfile @relation(fields: [workerId], references: [id])
  service  Service       @relation(fields: [serviceId], references: [id])

  @@id([workerId, serviceId])
}

model Availability {
  id         Int      @id @default(autoincrement())
  workerId   Int
  worker     WorkerProfile @relation(fields: [workerId], references: [id])
  dayOfWeek  Int      // 0-6 (Sun-Sat)
  startTime  String   // HH:mm
  endTime    String   // HH:mm
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Booking {
  id                 Int           @id @default(autoincrement())
  customerId         Int
  customer           User          @relation("customerBookings", fields: [customerId], references: [id])
  workerProfileId    Int?
  workerProfile      WorkerProfile? @relation("bookingsWorker", fields: [workerProfileId], references: [id])
  serviceId          Int
  service            Service       @relation(fields: [serviceId], references: [id])
  scheduledAt        DateTime
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING)
  paymentReference   String?
  paidAt             DateTime?
  totalPrice         Decimal?
  address            String?
  notes              String?
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  reviews            Review[]
  payments           Payment[]

  @@index([status])
  @@index([customerId])
  @@index([workerProfileId])
}

model Payment {
  id          Int           @id @default(autoincrement())
  bookingId   Int
  booking     Booking       @relation(fields: [bookingId], references: [id])
  customerId  Int
  customer    User          @relation(fields: [customerId], references: [id])
  amount      Decimal?
  status      PaymentStatus @default(PENDING)
  reference   String?
  createdAt   DateTime      @default(now())

  @@index([bookingId])
  @@index([customerId])
}

model Review {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  booking       Booking  @relation(fields: [bookingId], references: [id])
  
  reviewerId    Int
  reviewer      User     @relation("reviewsWritten", fields: [reviewerId], references: [id])
  
  revieweeId    Int
  reviewee      User     @relation("reviewsReceived", fields: [revieweeId], references: [id])
  
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  @@unique([bookingId, reviewerId])
}
