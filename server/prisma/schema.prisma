// Prisma schema for UrbanPro v2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  MORE_INFO
}

enum VerificationDocumentType {
  ID_PROOF
  EXPERIENCE_LETTER
  CERTIFICATION
  PORTFOLIO
  ADDRESS_PROOF
}

enum VerificationMediaType {
  VIDEO_INTRO
  PORTFOLIO_IMAGE
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  mobile        String    @unique
  passwordHash  String
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  emailVerifiedAt DateTime?
  profilePhotoUrl String?
  isProfileComplete Boolean @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  workerProfile WorkerProfile?

  bookingsCustomer Booking[] @relation("customerBookings")

  rating        Float     @default(0)
  totalReviews  Int       @default(0)

  reviewsWritten  Review[] @relation("reviewsWritten")
  reviewsReceived Review[] @relation("reviewsReceived")
  emailVerifications EmailVerification[]
  passwordResetTokens PasswordResetToken[]
  workerVerificationApplications WorkerVerificationApplication[]
  payments Payment[]
  emergencyContacts EmergencyContact[]
  notifications Notification[]
  sosAlerts     SOSAlert[]
  customerConversations Conversation[] @relation("CustomerConversations")
  workerConversations   Conversation[] @relation("WorkerConversations")
  messages              Message[]
  statusChanges         BookingStatusHistory[]
}

model EmailVerification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  token     String    @unique
  verified  Boolean   @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([email])
  @@index([token])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Address {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Service {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String?
  category     String?
  basePrice    Decimal?
  translations Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workers  WorkerService[]
  bookings Booking[]
}

enum VerificationLevel {
  BASIC
  DOCUMENTS
  VERIFIED
  PREMIUM
}

model WorkerProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?
  skills       Json?
  hourlyRate   Decimal?
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  serviceAreas Json?
  baseLatitude  Float?
  baseLongitude Float?
  serviceRadius Int?     @default(10) // Coverage radius in KM
  isVerified   Boolean  @default(false)
  isProbation  Boolean  @default(true)
  verificationScore Int? 
  verificationLevel VerificationLevel @default(BASIC)

  availability Availability[]
  services     WorkerService[]
  bookingsWorker Booking[] @relation("bookingsWorker")
  location     WorkerLocation?
}

model WorkerLocation {
  id              Int    @id @default(autoincrement())
  workerProfileId Int    @unique
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id])
  latitude        Float
  longitude       Float
  isOnline        Boolean @default(false)
  lastUpdated     DateTime @default(now())
}

model WorkerVerificationApplication {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      VerificationStatus @default(PENDING)
  score       Int?      
  notes       String?
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  documents   WorkerVerificationDocument[]
  references  WorkerVerificationReference[]
  media       WorkerVerificationMedia[]

  @@index([userId])
  @@index([status])
}

model WorkerVerificationDocument {
  id            Int       @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          VerificationDocumentType
  url           String
  createdAt     DateTime  @default(now())

  @@index([applicationId])
  @@index([type])
}

model WorkerVerificationReference {
  id            Int       @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  relation      String?
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([applicationId])
  @@index([phone])
}

model WorkerVerificationMedia {
  id            Int       @id @default(autoincrement())
  applicationId Int
  application   WorkerVerificationApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          VerificationMediaType
  url           String
  createdAt     DateTime  @default(now())

  @@index([applicationId])
  @@index([type])
}

model WorkerService {
  workerId Int
  serviceId Int
  worker   WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service  Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([workerId, serviceId])
}

model Availability {
  id         Int      @id @default(autoincrement())
  workerId   Int
  worker     WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      // 0-6 (Sun-Sat)
  startTime  String   // HH:mm
  endTime    String   // HH:mm
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([workerId, dayOfWeek, startTime, endTime])
}

model Booking {
  id                 Int           @id @default(autoincrement())
  customerId         Int
  customer           User          @relation("customerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  workerProfileId    Int?
  workerProfile      WorkerProfile? @relation("bookingsWorker", fields: [workerProfileId], references: [id], onDelete: Cascade)
  serviceId          Int
  service            Service       @relation(fields: [serviceId], references: [id])
  scheduledAt        DateTime
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING)
  paymentReference   String?
  paidAt             DateTime?
  totalPrice         Decimal?
  address            String?
  latitude           Float?
  longitude          Float?
  notes              String?
  estimatedDuration  Int?       // Duration in minutes (default: 120 if not provided)
  cancellationReason         String?
  cancellationPenaltyPercent Int?       // 0=free, 25/50/100 = penalty %
  
  // OTP Verification Fields
  startOtp          String?    // 4-digit code
  completionOtp     String?    // 4-digit code (for job completion if needed)
  otpGeneratedAt    DateTime?
  startedAt         DateTime?  // When job actually started (OTP verified)
  completedAt       DateTime?  // When job was marked complete
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  reviews            Review[]
  payments           Payment[]
  photos             BookingPhoto[]
  sosAlerts          SOSAlert[]
  conversation       Conversation?
  sessions           BookingSession[]
  statusHistory      BookingStatusHistory[]

  @@index([status])
  @@index([customerId])
  @@index([workerProfileId])
  @@index([scheduledAt])
  @@index([paymentStatus])
}

model Payment {
  id          Int           @id @default(autoincrement())
  bookingId   Int
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId  Int
  customer    User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount      Decimal?
  status      PaymentStatus @default(PENDING)
  reference   String?
  createdAt   DateTime      @default(now())

  @@index([bookingId])
  @@index([customerId])
}

model Review {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  reviewerId    Int
  reviewer      User     @relation("reviewsWritten", fields: [reviewerId], references: [id], onDelete: Cascade)
  
  revieweeId    Int
  reviewee      User     @relation("reviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  @@unique([bookingId, reviewerId])
  @@index([bookingId])
  @@index([reviewerId])
  @@index([revieweeId])
}

model BookingPhoto {
  id        Int      @id @default(autoincrement())
  bookingId Int
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  url       String
  type      PhotoType
  caption   String?
  createdAt DateTime @default(now())
}

enum PhotoType {
  BEFORE
  AFTER
}

model EmergencyContact {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  phone    String
  relation String // "Parent", "Spouse", "Friend"
}

model SOSAlert {
  id        Int      @id @default(autoincrement())
  bookingId Int
  booking   Booking  @relation(fields: [bookingId], references: [id])
  triggeredBy Int
  triggeredByUser User @relation(fields: [triggeredBy], references: [id], onDelete: Cascade)
  latitude  Float?
  longitude Float?
  status    SOSStatus @default(ACTIVE)
  resolvedAt DateTime?
  createdAt DateTime @default(now())

  @@index([triggeredBy])
}

enum SOSStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "BOOKING_UPDATE", "REVIEW_RECEIVED", "PAYMENT", "SYSTEM"
  title     String
  message   String
  data      Json?    // Extra context like { bookingId: 5 }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model Conversation {
  id        Int       @id @default(autoincrement())
  bookingId Int?      @unique
  booking   Booking?  @relation(fields: [bookingId], references: [id])
  
  // Members
  customerId Int
  customer   User     @relation("CustomerConversations", fields: [customerId], references: [id])
  workerUserId Int
  worker     User     @relation("WorkerConversations", fields: [workerUserId], references: [id])
  
  messages  Message[]
  lastMessageAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([workerUserId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int
  sender         User         @relation(fields: [senderId], references: [id])
  content        String       @db.Text
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
}

model BookingSession {
  id          Int       @id @default(autoincrement())
  bookingId   Int
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sessionDate DateTime
  startTime   DateTime?
  endTime     DateTime?
  isActive    Boolean   @default(false)
  startOtp    String?
  otpVerified Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([bookingId])
  @@index([sessionDate])
}

model BookingStatusHistory {
  id         Int      @id @default(autoincrement())
  bookingId  Int
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  changedBy  Int?
  changer    User?    @relation(fields: [changedBy], references: [id])
  reason     String?
  createdAt  DateTime @default(now())

  @@index([bookingId])
  @@index([changedBy])
}
