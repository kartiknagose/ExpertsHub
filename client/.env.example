# Client environment template (safe to commit)
# Copy to .env for local development and fill with values as needed.

VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_RAZORPAY_KEY_ID=
VITE_GOOGLE_PLACES_API_KEY=
VITE_APP_ENV=development

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Sign up at https://clerk.com → create an application → copy the
# "Publishable key" from the "API Keys" section.
# This key is safe to expose to the browser.
VITE_CLERK_PUBLISHABLE_KEY=
# ─────────────────────────────────────────────────────────────────────────────
