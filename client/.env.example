# UrbanPro V2 — Client Environment Variables
# Copy this file to .env and fill in the values

# Backend API URL
VITE_API_URL=http://localhost:3000/api

# Application name
VITE_APP_NAME=UrbanPro

# UI Preview Mode — set to true ONLY for local UI development without backend
# WARNING: Setting this to true in production bypasses authentication!
VITE_UI_PREVIEW_MODE=false
